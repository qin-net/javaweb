<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>大黑山大学学报期刊投稿管理系统</display-name>

    <!-- CORS Filter -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.journal.web.CorsFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Encoding Filter -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.journal.web.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlet 映射 -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.journal.web.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/api/dashboard/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PaperServlet</servlet-name>
        <servlet-class>com.journal.web.PaperServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PaperServlet</servlet-name>
        <url-pattern>/api/papers/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReviewServlet</servlet-name>
        <servlet-class>com.journal.web.ReviewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReviewServlet</servlet-name>
        <url-pattern>/api/reviews/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AuthorServlet</servlet-name>
        <servlet-class>com.journal.web.AuthorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthorServlet</servlet-name>
        <url-pattern>/api/authors/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReviewerServlet</servlet-name>
        <servlet-class>com.journal.web.ReviewerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReviewerServlet</servlet-name>
        <url-pattern>/api/reviewers/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AssignmentServlet</servlet-name>
        <servlet-class>com.journal.web.AssignmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AssignmentServlet</servlet-name>
        <url-pattern>/api/assignments/*</url-pattern>
    </servlet-mapping>
</web-app>
